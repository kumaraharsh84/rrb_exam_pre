{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowExplanationCacheAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-south-1:YOUR_ACCOUNT_ID:table/rrb_explanations",
        "arn:aws:dynamodb:ap-south-1:YOUR_ACCOUNT_ID:table/rrb_explanations/index/question_hash-index"
      ]
    },
    {
      "Sid": "AllowBedrockExplanationGeneration",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowLambdaLogging",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    }
  ]
}
